# TravelSync Client Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit actual API keys to version control

# Backend API Base URL
# Development: http://localhost:3000/api
# Production: https://your-api-domain.com/api
VITE_API_BASE_URL=http://localhost:3000/api

# Google Maps API Key
# Get from: https://console.cloud.google.com/apis/credentials
# Restrict to: Maps JavaScript API, Places API
# Restrict domain to: your-frontend-domain.com
VITE_GOOGLE_MAPS_KEY=AIzaSyDb3nMJGNuKCWt3oiD8yIMKqANPQ-Ep3rg


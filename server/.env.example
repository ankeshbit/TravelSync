# TravelSync Server Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit actual secrets to version control

# MongoDB Connection String (Atlas or local)
# Example: mongodb+srv://user:pass@cluster.mongodb.net/travelsync?retryWrites=true&w=majority
MONGO_URI=mongodb+srv://Cluster0:0P31NqxmsYL6sGNu@cluster0.40hphfj.mongodb.net/travelsync

# JWT Secret for token signing (use a strong random string, min 32 characters)
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"

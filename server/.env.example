# TravelSync Server Environment Variables
# Copy this file to .env and fill in your actual values
# DO NOT commit .env to version control

# MongoDB Connection String
# Get from: https://cloud.mongodb.com
# Format: mongodb+srv://username:password@cluster.mongodb.net/dbname
MONGO_URI=mongodb+srv://your-username:your-password@your-cluster.mongodb.net/travelsync

# JWT Secret — must be a random string, minimum 32 characters
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET=replace-with-random-32-char-string

# JWT Refresh Secret — must be different from JWT_SECRET
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
REFRESH_SECRET=replace-with-another-random-32-char-string

# Frontend URL for CORS (no trailing slash)
ALLOWED_ORIGIN=http://localhost:5173

# Server Port
PORT=3000

# Node Environment (development | production)
NODE_ENV=development

# Groq API Key for AI Trip Planner
# Get from: https://console.groq.com
GROQ_API_KEY=gsk_your-groq-api-key-here

# Email credentials for OTP
EMAIL_USER=your-email@gmail.com
EMAIL_PASS=your-app-password-here
